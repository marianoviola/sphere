---
import Base from "../layouts/Base.astro";
import Hero from "../components/Hero.astro";

const description =
  "Sphere turns articles, documents, datasets, and media into licensed, provenance-aware fragments you validate locally and publish to a node you run yourself.";
---

<Base
  title="Sphere - Prepare your public knowledge for AI agents"
  description={description}
  ogDescription={description}
  path="/"
>
  <main>
    <Hero />

    <section class="section" id="intelligence">
      <div class="section-heading">
        <p class="eyebrow">What your fragments carry</p>
        <h2>Understand what your content becomes when agents read it.</h2>
      </div>
      <div class="report-grid">
        <article class="report-item">
          <span class="metric">01</span>
          <h3>Provenance</h3>
          <p>Sources, authors, canonical links, transformations, and rights declarations stay attached to every fragment.</p>
        </article>
        <article class="report-item">
          <span class="metric">02</span>
          <h3>Readiness</h3>
          <p>The plugin checks structure, license, media descriptions, data notes, and access policy, and reports the gaps.</p>
        </article>
        <article class="report-item">
          <span class="metric">03</span>
          <h3>Relations</h3>
          <p>Fragments cite, support, extend, update, contradict, or join constellations instead of remaining isolated files.</p>
        </article>
        <article class="report-item">
          <span class="metric">04</span>
          <h3>Monitoring</h3>
          <p>See discovery, manifest, and access events on your own Node through read-only owner endpoints and a privacy-lean ledger.</p>
        </article>
      </div>
    </section>

    <section class="section protocol" id="protocol">
      <div class="section-heading">
        <p class="eyebrow">Local-first, then your own node</p>
        <h2>A place to prepare. A node to publish.</h2>
      </div>
      <div class="flow" aria-label="Sphere publishing path">
        <div>
          <span>Input</span>
          <strong>Articles, docs, datasets, media</strong>
        </div>
        <div>
          <span>Plugin</span>
          <strong>Prepare, validate, and report locally</strong>
        </div>
        <div>
          <span>Fragment</span>
          <strong>Manifest, Markdown, sources, relations</strong>
        </div>
        <div>
          <span>Node</span>
          <strong>Publish to access you control</strong>
        </div>
      </div>
    </section>
  </main>
</Base>
