---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";

const docs = (await getCollection("docs")).sort((a, b) => a.data.order - b.data.order);

const statusLabel: Record<string, string> = {
  shipped: "shipped",
  mixed: "shipped + vision",
  vision: "vision",
};
---

<Base
  title="Documentation - Sphere"
  description="Sphere documentation and theory: what ships today, and the broader concept behind agent-readable public knowledge."
  ogTitle="Sphere documentation"
  path="/docs/"
>
  <Nav variant="page" />

  <main class="note-page">
    <article class="note">
      <p class="eyebrow">Documentation and theory</p>
      <h1>Docs</h1>

      <p class="docs-banner">
        <strong>What ships today is the self-hostable Sphere Node and the Claude
        plugin.</strong> The Node runs on Cloudflare and serves your fragments;
        the plugin validates, scores, and scaffolds fragments locally. Everything
        else in these documents - managed services, payment coordination, revenue
        attribution, a registry, a hosted sandbox - describes the broader concept
        and direction, not current services. Each document is labeled
        <span class="badge badge-shipped">shipped</span>,
        <span class="badge badge-mixed">shipped + vision</span>, or
        <span class="badge badge-vision">vision</span>.
      </p>

      <ul class="docs-list">
        {
          docs.map((doc) => (
            <li>
              <a href={`/docs/${doc.id}/`}>
                <h3>
                  {doc.data.title}
                  <span class={`badge badge-${doc.data.status}`}>{statusLabel[doc.data.status]}</span>
                </h3>
                <p>{doc.data.description}</p>
              </a>
            </li>
          ))
        }
      </ul>
    </article>
  </main>
</Base>
