---
import { getCollection, render } from "astro:content";
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";

export async function getStaticPaths() {
  const docs = (await getCollection("docs")).sort((a, b) => a.data.order - b.data.order);
  return docs.map((entry, index) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prev: index > 0 ? docs[index - 1] : null,
      next: index < docs.length - 1 ? docs[index + 1] : null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

const statusLabel: Record<string, string> = {
  shipped: "shipped",
  mixed: "shipped + vision",
  vision: "vision",
};
---

<Base
  title={`${entry.data.title} - Sphere docs`}
  description={entry.data.description}
  ogTitle={`${entry.data.title} - Sphere docs`}
  ogType="article"
  path={`/docs/${entry.id}/`}
>
  <Nav variant="page" />

  <main class="doc-prose">
    <a class="doc-back" href="/docs">&larr; All docs</a>
    <p><span class={`badge badge-${entry.data.status}`}>{statusLabel[entry.data.status]}</span></p>
    {entry.data.note && <p class="doc-note">{entry.data.note}</p>}
    <Content />

    <nav class="doc-pager" aria-label="Documentation">
      {
        prev ? (
          <a class="doc-pager-link doc-pager-prev" href={`/docs/${prev.id}/`}>
            <span class="doc-pager-dir">&larr; Previous</span>
            <span class="doc-pager-title">{prev.data.title}</span>
          </a>
        ) : (
          <span />
        )
      }
      {
        next ? (
          <a class="doc-pager-link doc-pager-next" href={`/docs/${next.id}/`}>
            <span class="doc-pager-dir">Next &rarr;</span>
            <span class="doc-pager-title">{next.data.title}</span>
          </a>
        ) : (
          <span />
        )
      }
    </nav>
  </main>
</Base>

<script>
  import mermaid from "mermaid";

  mermaid.initialize({
    startOnLoad: false,
    securityLevel: "loose",
    fontFamily: "Inter, system-ui, sans-serif",
    theme: "base",
    themeVariables: {
      darkMode: true,
      background: "transparent",
      primaryColor: "#0c1722",
      primaryBorderColor: "#7f93a3",
      primaryTextColor: "#eef4fb",
      secondaryColor: "#0c1722",
      tertiaryColor: "#0c1722",
      lineColor: "#8aa0b2",
      textColor: "#cdd9e3",
      // Sequence diagrams
      actorBkg: "#0c1722",
      actorBorder: "#7f93a3",
      actorTextColor: "#eef4fb",
      actorLineColor: "#7f93a3",
      signalColor: "#8aa0b2",
      signalTextColor: "#cdd9e3",
      noteBkgColor: "#10202e",
      noteTextColor: "#cdd9e3",
      noteBorderColor: "#33485a",
    },
  });

  const nodes = document.querySelectorAll<HTMLElement>("pre.mermaid");
  if (nodes.length) {
    mermaid.run({ nodes });
  }
</script>
