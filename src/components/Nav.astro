---
// Primary navigation. Two variants: "hero" sits transparently over the canvas;
// "page" is a bordered top bar used on docs and notes pages.
interface Props {
  variant?: "hero" | "page";
}
const { variant = "hero" } = Astro.props;
const navClass = variant === "page" ? "nav note-nav" : "nav";
---

<header class={navClass} aria-label="Primary">
  <a class="brand" href="/" aria-label="Sphere home">
    <span class="brand-mark"></span>
    <span>Sphere</span>
  </a>
  <nav class="nav-links">
    {
      variant === "hero" ? (
        <>
          <a href="#intelligence">Intelligence</a>
          <a href="#protocol">Protocol</a>
          <a href="/docs">Docs</a>
          <a href="https://github.com/marianoviola/sphere-node">GitHub</a>
        </>
      ) : (
        <>
          <a href="/">Home</a>
          <a href="/docs">Docs</a>
          <a href="https://github.com/marianoviola/sphere-node">GitHub</a>
        </>
      )
    }
  </nav>
</header>
